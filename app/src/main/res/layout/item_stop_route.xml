<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="70dp">


    <FrameLayout
        android:id="@+id/timelineLayout"
        android:layout_width="40dp"
        android:layout_height="match_parent">


        <!-- CONNECTED LINE -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <View
                android:id="@+id/topLine"
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#16A34A"/>


            <TextView
                android:id="@+id/stopNumber"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#16A34A"
                android:background="@drawable/stop_circle_bg"/>


            <View
                android:id="@+id/bottomLine"
                android:layout_width="4dp"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="#16A34A"/>

        </LinearLayout>


        <!-- ARROW BETWEEN NUMBERS -->
        <TextView
            android:id="@+id/stopArrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="48dp"
            android:text="↓"
            android:textColor="#16A34A"
            android:textSize="30sp"
            android:textStyle="bold"/>

    </FrameLayout>



    <TextView
        android:id="@+id/stopNameTxt"

        android:layout_width="210dp"
        android:layout_height="wrap_content"

        android:layout_toEndOf="@id/timelineLayout"

        android:layout_centerVertical="true"

        android:layout_marginStart="12dp"

        android:layout_marginTop="-8dp"

        android:maxLines="2"

        android:gravity="center_vertical"

        android:textColor="#111111"

        android:textSize="13sp"

        android:textStyle="bold"/>



    <TextView
        android:id="@+id/stopStatusTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/stopNameTxt"
        android:layout_toEndOf="@id/timelineLayout"
        android:layout_marginStart="12dp"
        android:textColor="#16A34A"
        android:textSize="10sp"/>



    <TextView
        android:id="@+id/stopTimeTxt"

        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_alignParentEnd="true"

        android:layout_centerVertical="true"

        android:layout_marginEnd="12dp"

        android:layout_marginTop="-8dp"

        android:gravity="center_vertical"

        android:textColor="#111111"

        android:textSize="13sp"

        android:textStyle="bold"/>

</RelativeLayout>