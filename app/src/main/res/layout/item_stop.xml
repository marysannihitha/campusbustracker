<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal">



    <!-- NUMBER + CONNECTOR -->
    <LinearLayout
        android:layout_width="32dp"
        android:layout_height="72dp"
        android:orientation="vertical"
        android:gravity="top|center_horizontal">



        <!-- NUMBER -->
        <TextView
            android:id="@+id/stopNumber"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:text="1"
            android:textColor="#16A34A"
            android:textStyle="bold"
            android:background="@drawable/stop_circle_bg"/>



        <!-- CONNECTED LINE -->
        <View
            android:layout_width="2dp"
            android:layout_height="40dp"
            android:layout_marginTop="-2dp"
            android:background="#16A34A"/>

    </LinearLayout>



    <!-- STOP -->
    <EditText
        android:id="@+id/stopEt"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:hint="Enter stop name"
        android:background="@drawable/stop_input_bg"
        android:paddingStart="12dp"/>



    <!-- TIME -->
    <TextView
        android:id="@+id/stopTimeTxt"
        android:layout_width="90dp"
        android:layout_height="44dp"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:text="--:--"
        android:textColor="#9CA3AF"
        android:background="@drawable/stop_input_bg"/>

</LinearLayout>