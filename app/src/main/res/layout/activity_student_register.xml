<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_media_previous"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create Student Account"
            android:textColor="#4B2BD6"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your details to register"
            android:textColor="#555555"
            android:textSize="14sp"
            android:layout_marginTop="6dp"/>

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/student_icon"
            android:layout_gravity="center"
            android:layout_marginTop="25dp"/>


        <EditText
            android:id="@+id/nameEt"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Full Name"
            android:layout_marginTop="25dp"/>

        <EditText
            android:id="@+id/emailEt"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Email Address"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/phoneEt"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Phone Number"
            android:layout_marginTop="12dp"/>



        <EditText
            android:id="@+id/passwordEt"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Password"
            android:inputType="textPassword"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/confirmPasswordEt"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Confirm Password"
            android:inputType="textPassword"
            android:layout_marginTop="12dp"/>


        <CheckBox
            android:id="@+id/termsCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="I agree to the Terms &amp; Conditions and Privacy Policy"
            android:textColor="#555555"
            android:layout_marginTop="15dp"/>


        <Button
            android:id="@+id/registerBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Register as Student"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:backgroundTint="#5A2DE1"
            android:layout_marginTop="20dp"/>


        <TextView
            android:id="@+id/loginBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Login"
            android:textColor="#5A2DE1"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"/>

    </LinearLayout>

</ScrollView>