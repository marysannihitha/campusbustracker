<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/mainContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#F8F8F8">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="18dp"
            android:paddingBottom="24dp">


            <!-- HEADER -->
            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="48dp">


                <!-- BACK BUTTON -->
                <ImageView
                    android:id="@+id/backBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_back_g" />


                <!-- TITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Route &amp; Stops"
                    android:textColor="#111111"
                    android:textStyle="bold"
                    android:textSize="16sp" />

            </RelativeLayout>



            <!-- ROUTE CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="82dp"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="14dp">


                    <!-- ROUTE NUMBER CIRCLE -->
                    <TextView
                        android:id="@+id/busCircle"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:gravity="center"
                        android:text="1"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:background="@drawable/green_circle_bg" />


                    <!-- ROUTE ID -->
                    <TextView
                        android:id="@+id/routeIdTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toEndOf="@id/busCircle"
                        android:layout_marginStart="12dp"
                        android:text="RTE-001"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:textSize="14sp" />


                    <!-- ROUTE NAME -->
                    <TextView
                        android:id="@+id/routeNameTxt"
                        android:layout_width="180dp"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/routeIdTxt"
                        android:layout_toEndOf="@id/busCircle"
                        android:layout_marginStart="12dp"
                        android:layout_marginTop="2dp"
                        android:text="College to City Center"
                        android:textColor="#6B7280"
                        android:textSize="12sp"
                        android:maxLines="1"/>


                    <!-- STATUS -->
                    <TextView
                        android:id="@+id/statusTxt"
                        android:layout_width="74dp"
                        android:layout_height="28dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:gravity="center"
                        android:text="On Time"
                        android:textStyle="bold"
                        android:textSize="11sp"
                        android:textColor="#16A34A"
                        android:background="@drawable/status_bg_green" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>



            <!-- STOPS CARD -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="22dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:id="@+id/stopsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    >

                    <!-- STOPS ADDED DYNAMICALLY -->

                </LinearLayout>

            </androidx.cardview.widget.CardView>



            <!-- EDIT BUTTON -->
            <androidx.cardview.widget.CardView
                android:id="@+id/editBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="18dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#16A34A">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="✎   Edit Route"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </androidx.cardview.widget.CardView>



            <!-- TRACK -->
            <androidx.cardview.widget.CardView
                android:id="@+id/trackBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#16A34A">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="📍   Track on Map"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </androidx.cardview.widget.CardView>



            <androidx.cardview.widget.CardView
                android:id="@+id/joinBusBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#5B21B6">

                <TextView
                    android:id="@+id/joinBusTxt"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🚌   Join Bus"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"/>

            </androidx.cardview.widget.CardView>



            <!-- DELETE -->
            <androidx.cardview.widget.CardView
                android:id="@+id/deleteBtn"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#EF4444">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text="🗑   Delete Route"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp" />

            </androidx.cardview.widget.CardView>


        </LinearLayout>

    </ScrollView>


    <!-- FOOTER -->
    <include
        android:id="@+id/footer"
        layout="@layout/footer_layout"
        android:layout_width="match_parent"
        android:layout_height="70dp"/>
</LinearLayout>