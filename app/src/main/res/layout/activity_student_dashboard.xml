<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">


    <!-- FOOTER FIXED AT BOTTOM -->
    <include
        android:id="@+id/footer"
        layout="@layout/footer_layout"
        android:layout_width="0dp"
        android:layout_height="70dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/footer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">


            <!-- TOP -->
            <ImageView
                android:visibility="gone"
                android:id="@+id/menuBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="25dp"
                android:layout_marginTop="28dp"
                android:src="@drawable/ic_menu"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>

            <ImageView
                android:visibility="gone"
                android:id="@+id/notificationBtn"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginEnd="25dp"
                android:layout_marginTop="55dp"
                android:src="@drawable/ic_notification"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>


            <!-- GREETING -->
            <TextView
                android:id="@+id/nameTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:layout_marginTop="35dp"
                android:text="Hello, Priya!"
                android:textColor="#000000"
                android:textSize="28sp"
                android:textStyle="bold"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/menuBtn"/>

            <TextView
                android:id="@+id/subTitleTxt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="25dp"
                android:layout_marginTop="6dp"
                android:text="Track your bus in real time"
                android:textColor="#777777"
                android:textSize="15sp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/nameTxt"/>


            <!-- PURPLE CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/topCard"
                android:layout_width="0dp"
                android:layout_height="170dp"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="#5B2EFF"
                app:cardCornerRadius="20dp"
                app:layout_constraintTop_toBottomOf="@id/subTitleTxt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/nextBusTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next Bus"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/routeTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/nextBusTxt"
                        android:layout_marginTop="8dp"
                        android:text="College to City Center"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/busTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/routeTxt"
                        android:layout_marginTop="8dp"
                        android:text="R001"
                        android:textColor="#FFFFFF"/>

                    <ImageView
                        android:layout_width="140dp"
                        android:layout_height="80dp"
                        android:layout_alignParentBottom="true"
                        android:layout_alignParentEnd="true"
                        android:src="@drawable/bus_illustration"/>

                </RelativeLayout>

            </androidx.cardview.widget.CardView>


            <!-- INFO -->
            <LinearLayout
                android:id="@+id/infoLayout"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="18dp"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="20dp"
                android:orientation="vertical"
                app:layout_constraintTop_toBottomOf="@id/topCard"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">


                <!-- Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:background="@drawable/dashboard_white_card"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:text="Estimated Arrival"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/arrivalValueTxt"
                            android:text="10:15 AM"
                            android:textColor="#5A31F4"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/arrivalSubTxt"
                            android:text="12 min away"
                            android:textColor="#777777"
                            android:textSize="13sp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                    </LinearLayout>


                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/dashboard_white_card"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/busNumberTitle"
                            android:text="Bus Number"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/busNumberValueTxt"
                            android:layout_below="@id/busNumberTitle"
                            android:text="101"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_bus_purple"/>

                    </RelativeLayout>

                </LinearLayout>


                <!-- Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">


                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:background="@drawable/dashboard_white_card"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/locationTitle"
                            android:text="Current Location"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/locationValueTxt"
                            android:layout_below="@id/locationTitle"
                            android:text="Near City Mall"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_location_purple"/>

                    </RelativeLayout>


                    <RelativeLayout
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/dashboard_white_card"
                        android:padding="16dp">

                        <TextView
                            android:id="@+id/seatTitle"
                            android:text="Seats Available"
                            android:textStyle="bold"
                            android:textSize="15sp"
                            android:textColor="#111111"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <TextView
                            android:id="@+id/seatsValueTxt"
                            android:layout_below="@id/seatTitle"
                            android:text="15 / 36"
                            android:textColor="#5A31F4"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:layout_marginTop="10dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"/>

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_alignParentBottom="true"
                            android:layout_alignParentEnd="true"
                            android:src="@drawable/ic_seat_purple"/>

                    </RelativeLayout>

                </LinearLayout>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>



    </ScrollView>

    <TextView
        android:id="@+id/permissionTxt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#EF4444"
        android:textSize="14sp"
        android:visibility="gone"/>

</androidx.constraintlayout.widget.ConstraintLayout>