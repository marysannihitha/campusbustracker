<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    android:id="@+id/rootLayout"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <!-- MAP AREA -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">


        <fragment
            android:id="@+id/mapFragment"
            android:name="com.google.android.gms.maps.SupportMapFragment"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>


        <ImageView
            android:id="@+id/backBtn"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="16dp"
            android:src="@drawable/ic_back_g"/>

    </FrameLayout>

    <!-- TRIP CARD -->
    <androidx.cardview.widget.CardView
        android:id="@+id/tripCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="10dp"
        app:cardCornerRadius="14dp"
        app:cardElevation="3dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="14dp">


            <!-- NEXT STOP CARD -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <!-- NEXT STOP -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Next Stop"
                        android:textColor="#666666"
                        android:textSize="11sp"/>




                    <TextView
                        android:id="@+id/nextStopTxt"
                        android:layout_width="220dp"
                        android:layout_height="wrap_content"
                        android:maxLines="2"
                        android:ellipsize="end"
                        android:text="Main Gate"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:textSize="10sp"/>
                </LinearLayout>


                <!-- ETA -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ETA"
                        android:textColor="#666666"
                        android:textSize="11sp"/>


                    <TextView
                        android:id="@+id/etaTxt"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5 min"
                        android:textStyle="bold"
                        android:textColor="#111111"
                        android:textSize="10sp"/>

                </LinearLayout>

            </RelativeLayout>



            <!-- DRIVER BUTTONS -->
            <TextView
                android:id="@+id/tripBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Start Trip"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/trip_btn_green"/>


            <TextView
                android:id="@+id/updateStatusBtn"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:gravity="center"
                android:text="Update Status"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:background="@drawable/trip_btn_green"/>


            <!-- STUDENT STATUS -->
            <TextView
                android:id="@+id/statusTxt"
                android:layout_width="80dp"
                android:layout_height="28dp"
                android:layout_marginTop="14dp"
                android:gravity="center"
                android:text="Active"
                android:textSize="11sp"
                android:textStyle="bold"
                android:textColor="#00A650"
                android:background="#DFF7E8"
                android:visibility="gone"/>


            <TextView
                android:id="@+id/statusNoteTxt"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="12sp"
                android:textColor="#666666"
                android:visibility="gone"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- FOOTER -->
    <include
        android:id="@+id/footer"
        layout="@layout/footer_layout"
        android:layout_width="match_parent"
        android:layout_height="70dp"/>

</LinearLayout>