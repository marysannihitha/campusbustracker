<?xml version="1.0" encoding="utf-8"?>

<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- WHITE BACKGROUND -->
    <solid
        android:color="#FFFFFF"/>


    <!-- SOFT BORDER -->
    <stroke
        android:width="1dp"
        android:color="#D1D5DB"/>


    <!-- ROUNDED CORNERS -->
    <corners
        android:radius="10dp"/>


    <!-- INNER SPACING -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="8dp"
        android:bottom="8dp"/>

</shape>